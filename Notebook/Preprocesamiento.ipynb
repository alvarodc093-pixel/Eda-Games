    "    ax.set_xlabel(\"Porcentaje de Ventas Acumuladas (%)\", fontweight=\"semibold\", labelpad=10)\n",
    "    ax.set_ylabel(\"Plataforma / Consola\", fontweight=\"semibold\", labelpad=10)\n",
